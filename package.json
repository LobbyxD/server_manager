{
  "name": "minecraft-server-manager",
  "productName": "Minecraft Server Manager",
  "version": "1.0.1",
  "description": "Minecraft Server Manager",
  "author": "R2D2",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder && npm --prefix installer run package",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.danieldev.minecraft-server-manager",
    "productName": "Minecraft Server Manager",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "LobbyxD",
      "repo": "server_manager",
      "releaseType": "release"
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "dir"
      ]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
